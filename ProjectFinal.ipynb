   "metadata": {},
   "source": [
    "## Ingest Data into MongoDB\n",
    "### Load the CSV file into MongoDB to simulate a real data source"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "67b0239f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Successfully ingested 100000 records into MongoDB.\n"
     ]
    }
   ],
   "source": [
    "# Connect to MongoDB (Local or Atlas)\n",
    "# Replace 'your_connection_string' with your actual MongoDB URI\n",
    "client = pymongo.MongoClient(\"mongodb://localhost:27017/\")\n",
    "db = client[\"diabetes_db\"]\n",
    "collection = db[\"patients\"]\n",
    "\n",
    "# Load CSV and insert into MongoDB\n",
    "df_csv = pd.read_csv('diabetes_dataset.csv')\n",
    "data_dict = df_csv.to_dict(orient='records')\n",
    "\n",
    "# Clear collection and insert new data\n",
    "collection.delete_many({}) \n",
    "collection.insert_many(data_dict)\n",
    "\n",
    "print(f\"Successfully ingested {len(data_dict)} records into MongoDB.\")"
   ]
  },
